# Runtime
NODE_ENV=development
KB_REMINDER_TIMEZONE=America/Sao_Paulo
KB_API_HOST=127.0.0.1
KB_API_PORT=4310
KB_API_PROXY_TARGET=http://localhost:4310
KB_FRONTEND_HOST=127.0.0.1
KB_FRONTEND_PORT=4311
KB_FRONTEND_BASE_PATH=/
KB_TRUST_PROXY=false
KB_BODY_LIMIT=10mb
KB_LOG_PRETTY_CONSOLE=true

# File Logging (Winston with daily rotation)
KB_LOG_FILE_ENABLED=true
KB_LOG_DIR=/app/logs
KB_LOG_MAX_FILES=30
KB_LOG_MAX_SIZE=20m
KB_LOG_LEVEL=debug

# Production: Use /var/log/knowledge-base-api on VPS
# KB_LOG_DIR=/var/log/knowledge-base-api

# Docker/Postgres local
KB_POSTGRES_PORT=5438
KB_POSTGRES_DB=knowledge_base
KB_POSTGRES_USER=postgres
KB_POSTGRES_PASSWORD=postgres

# Browser/API origin trust (fixes signup/login 403 invalid_origin)
KB_PUBLIC_BASE_URL=http://127.0.0.1:4311
KB_API_PUBLIC_BASE_URL=http://127.0.0.1:4310
KB_ALLOWED_ORIGINS=http://127.0.0.1:4311,http://localhost:4311,http://127.0.0.1:4310,http://localhost:4310

# Browser extension IDs (comma-separated, for chrome-extension:// origins)
# Get your extension ID from chrome://extensions/ after loading the unpacked extension
KB_ALLOWED_EXTENSION_IDS=

# Webhook Paths
KB_WEBHOOK_SECRET=
KB_GITHUB_WEBHOOK_PATH=/api/webhooks/github-push
KB_INGEST_WEBHOOK_PATH=/api/webhooks/ingest
KB_WPP_WEBHOOK_PATH=/api/webhooks/whatsapp
KB_QUERY_WEBHOOK_PATH=/api/webhooks/query

# Auth
KB_ADMIN_EMAIL=admin@example.com
KB_ADMIN_PASSWORD=change-me
KB_JWT_ACCESS_SECRET=change-me-access-secret
KB_JWT_REFRESH_SECRET=change-me-refresh-secret
KB_ACCESS_TOKEN_TTL_SECONDS=900
KB_REFRESH_TOKEN_TTL_SECONDS=2592000
KB_GOOGLE_OAUTH_CLIENT_ID=
KB_GOOGLE_OAUTH_CLIENT_SECRET=
KB_GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:4310/api/auth/google/callback
KB_INTERNAL_SERVICE_TOKEN=change-me-internal-token

# Persistence
KB_DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5438/knowledge_base
KB_DATABASE_SSL_MODE=
KB_DATABASE_SSL_REJECT_UNAUTHORIZED=

# Private Supabase Storage for note markdown and attachment bytes
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
KB_SUPABASE_STORAGE_BUCKET=
KB_SUPABASE_CACHE_CONTROL=31536000

# Credentials encryption (base64 of 32 bytes)
KB_CREDENTIALS_ENCRYPTION_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# Guided integrations
KB_GITHUB_APP_INSTALL_URL=https://github.com/apps/your-app/installations/new
KB_GITHUB_APP_CALLBACK_PATH=/api/integrations/github-app/callback
KB_GITHUB_APP_ID=
KB_GITHUB_APP_PRIVATE_KEY=
KB_GITHUB_APP_WEBHOOK_SECRET=
# Max commits to offer importing during GitHub onboarding backfill (default: 5)
KB_GITHUB_BACKFILL_LIMIT=5
KB_WPP_WEBHOOK_API_KEY=
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE_NAME=
EVOLUTION_API_PUBLIC_URL=
KB_TELEGRAM_BOT_TOKEN=
KB_TELEGRAM_WEBHOOK_TOKEN=
# Legado/manual para automacoes antigas. O worker oficial de reminders usa o chat conectado no workspace.
KB_TELEGRAM_CHAT_ID=

# WhatsApp conversation timeout (in milliseconds)
WPP_CONVERSATION_TIMEOUT_MS=600000

# Managed AI integrations
KB_REVIEW_AI_PROVIDER=openrouter
KB_REVIEW_AI_BASE_URL=https://openrouter.ai/api/v1
KB_REVIEW_AI_MODEL=openrouter/auto
KB_REVIEW_AI_API_KEY=
KB_CONVERSATION_AI_PROVIDER=openrouter
KB_CONVERSATION_AI_BASE_URL=https://openrouter.ai/api/v1
KB_CONVERSATION_AI_MODEL=openrouter/auto
KB_CONVERSATION_AI_API_KEY=
# Defaults to KB_CONVERSATION_AI_* when left blank.
KB_PROJECT_BRIEF_AI_PROVIDER=
KB_PROJECT_BRIEF_AI_BASE_URL=
KB_PROJECT_BRIEF_AI_MODEL=
KB_PROJECT_BRIEF_AI_API_KEY=
# Defaults to KB_CONVERSATION_AI_* when left blank.
KB_PR_CONTEXT_AI_PROVIDER=
KB_PR_CONTEXT_AI_BASE_URL=
KB_PR_CONTEXT_AI_MODEL=
KB_PR_CONTEXT_AI_API_KEY=

# Audio Transcription AI (Defaulting to Gemini 2.5 Flash Native Audio Dialog)
KB_AUDIO_AI_PROVIDER=gemini
KB_AUDIO_AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
KB_AUDIO_AI_MODEL=gemini-2.5-flash
KB_AUDIO_AI_API_KEY=

# Embedding AI (semantic search)
# Provider options: 'gemini', 'openai' (for OpenAI or local Ollama), 'ollama' (bypasses api key check), 'openrouter'
# For local Ollama Nomic MoE setup (secured via proxy):
#   KB_EMBEDDING_AI_PROVIDER=ollama
#   KB_EMBEDDING_AI_BASE_URL=https://pedro-duarte.ddns.net/ollama/v1
#   KB_EMBEDDING_AI_MODEL=nomic-embed-text-v2-moe
#   KB_EMBEDDING_AI_API_KEY=your_proxy_bearer_token
KB_EMBEDDING_AI_PROVIDER=gemini
KB_EMBEDDING_AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
KB_EMBEDDING_AI_MODEL=gemini-embedding-001
KB_EMBEDDING_AI_API_KEY=

# Local Ollama service port (defaults to 11434)
KB_OLLAMA_PORT=11434

# Search and RAG Hyperparameters
KB_SEARCH_MIN_SIMILARITY=0.35
KB_SEARCH_CANDIDATE_LIMIT_MULTIPLIER=4
KB_SEARCH_HYBRID_VECTOR_WEIGHT=0.4
KB_SEARCH_HYBRID_KEYWORD_WEIGHT=0.6
KB_SEARCH_RRF_K=20
KB_RAG_MIN_SIMILARITY=0.45
KB_RAG_CANDIDATE_LIMIT=16
KB_RAG_HYBRID_VECTOR_WEIGHT=0.7
KB_RAG_HYBRID_KEYWORD_WEIGHT=0.3
KB_RAG_TOP_CHUNKS_LIMIT=10
KB_RAG_RRF_K=20

# Chunking Hyperparameters
KB_CHUNK_TARGET_TOKENS=500
KB_CHUNK_OVERLAP_TOKENS=50
KB_CHUNK_MIN_CHARS=30
KB_CHUNK_CODE_BLOCK_OVERLAP_LINES=8

# Embedding Dimension
KB_EMBEDDING_DIMENSION=768

# RabbitMQ (embedding queue)
KB_RABBITMQ_URL=amqp://kb:kb_dev@127.0.0.1:5672
KB_RABBITMQ_USER=kb
KB_RABBITMQ_PASSWORD=kb_dev
KB_RABBITMQ_PORT=5672
KB_RABBITMQ_MANAGEMENT_PORT=15672
KB_DISABLE_EMBEDDING_WORKER=false

# RabbitMQ (billing/webhook queue)
KB_RABBITMQ_BILLING_EXCHANGE=billing.webhooks
KB_RABBITMQ_BILLING_QUEUE=billing.webhooks.asaas
KB_RABBITMQ_BILLING_ROUTING_KEY=asaas.webhook
RABBITMQ_RETRY_DELAY_MS=15000
RABBITMQ_MAX_RETRIES=5
WEBHOOK_MAX_ATTEMPTS=10

# Asaas Payment Gateway
ASAAS_BASE_URL=https://api-sandbox.asaas.com/v3
ASAAS_ACCESS_TOKEN=your-asaas-api-access-token-here
ASAAS_WEBHOOK_TOKEN=your-configured-webhook-token-here
ASAAS_CUSTOMER_NOTIFICATIONS_DISABLED=true

# Stripe Payment Gateway
STRIPE_SECRET_KEY=your-stripe-secret-key-here
STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key-here
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret-here
ONLY_STRIPE=false

# Billing Workers
# Change Subscription Worker (applies scheduled downgrades/cycle changes)
CHANGE_SUBSCRIPTION_WORKER_AUTORUN=false

# Billing Worker (cancels PAST_DUE subscriptions after MAX_DAYS_PAST_DUE)
BILLING_WORKER_AUTORUN=false
MAX_DAYS_PAST_DUE=7

# Webhook Outbox Relay Worker (replays failed webhook events)
WEBHOOK_OUTBOX_RELAY_AUTORUN=false
WEBHOOK_OUTBOX_RELAY_CRON=*/1 * * * *
WEBHOOK_OUTBOX_RELAY_TIMEZONE=America/Sao_Paulo
WEBHOOK_OUTBOX_RELAY_BATCH_SIZE=100
WEBHOOK_OUTBOX_RELAY_MIN_AGE_SECONDS=30
WEBHOOK_OUTBOX_RELAY_MAX_ATTEMPTS=10

# Email interception for development
# When set to true, all emails are sent to DEV_EMAIL instead of the original recipient
DEV_EMAIL_INTERCEPT=false
DEV_EMAIL=pedroaugustoaduarte@gmail.com

# Email provider configuration
KB_EMAIL_PROVIDER=resend
KB_EMAIL_RESEND_API_KEY=
KB_EMAIL_FROM=Kote <no-reply@example.com>
KB_EMAIL_SMTP_HOST=
KB_EMAIL_SMTP_PORT=587
KB_EMAIL_SMTP_USER=
KB_EMAIL_SMTP_PASS=
KB_EMAIL_SMTP_SECURE=false
KB_EMAIL_QUEUE_EXCHANGE=kb.email
KB_EMAIL_QUEUE_NAME=kb.email.send
KB_EMAIL_QUEUE_ROUTING_KEY=kb.email.send
KB_EMAIL_WORKER_AUTORUN=true

# Test email authentication secret (for test email endpoints)
KB_TEST_EMAIL_AUTH_SECRET=change-me-test-email-secret

# Email branding (optional, defaults to Kote and icon-512.png)
APP_NAME=Kote
APP_LOGO_URL=

# Push Notifications (VAPID)
KB_VAPID_PUBLIC_KEY=
KB_VAPID_PRIVATE_KEY=

# Frontend build configuration
VITE_KB_FRONTEND_BASE_PATH=/
VITE_KB_API_BASE_PATH=/api

# WhatsApp bot number for connection flow (digits only, with country code)
VITE_WHATSAPP_NUMBER=5531992504889

# Telegram bot username for connection flow (without @)
VITE_TELEGRAM_BOT_USERNAME=kb_notes_bot

# File size limits (in bytes)
KB_ATTACHMENT_MAX_SIZE_BYTES=10485760
KB_AVATAR_MAX_SIZE_BYTES=3145728
VITE_ATTACHMENT_MAX_SIZE_BYTES=10485760
