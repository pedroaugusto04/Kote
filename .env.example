# =============================================================================
# Kote - Environment Configuration
# =============================================================================
# This file contains all environment variables for the Kote application.
# Variables are organized by functional area and marked as [REQUIRED] or [OPTIONAL].
#
# For self-hosting, you MUST configure all [REQUIRED] variables.
# [OPTIONAL] variables are not required to start Kote, but many features (such as RAG, AI responses, file uploads, OAuth, email, and integrations) require configuring their respective variables.
#
# Quick Start for Self-Hosting:
# 1. Copy this file to .env
# 2. Configure all [REQUIRED] variables below
# 3. Run: docker-compose up -d
# =============================================================================

# -----------------------------------------------------------------------------
# [REQUIRED] MINIMUM CONFIGURATION
# -----------------------------------------------------------------------------
# 1. Database connection (PostgreSQL with pgvector extension)
KB_DATABASE_URL=postgres://user:password@localhost:5432/knowledge_base

# 2. JWT secrets (generate with: openssl rand -base64 32)
KB_JWT_ACCESS_SECRET=change-me-access-secret-generate-random-string
KB_JWT_REFRESH_SECRET=change-me-refresh-secret-generate-random-string

# 3. Internal service token (generate with: openssl rand -base64 32)
KB_INTERNAL_SERVICE_TOKEN=change-me-internal-service-token

# 4. Credentials encryption key (generate with: openssl rand -base64 32)
KB_CREDENTIALS_ENCRYPTION_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# -----------------------------------------------------------------------------
# [REQUIRED FOR RAG/EMBEDDINGS]
# -----------------------------------------------------------------------------
# RabbitMQ connection (required for background processing of embeddings)
# Required for: embeddings, webhooks, email queue, weekly summaries, GitHub backfill
KB_RABBITMQ_URL=amqp://kb:kb_dev@localhost:5672

# Embedding AI for semantic search (required for RAG functionality)
# Configure via KB_DEFAULT_EMBEDDING_AI_* in the AI CONFIGURATION section below

# -----------------------------------------------------------------------------
# [OPTIONAL] ADMIN USER
# -----------------------------------------------------------------------------
# Admin user credentials (created on first run if configured)
# If not configured, users can self-register via the interface
KB_ADMIN_EMAIL=admin@example.com
KB_ADMIN_PASSWORD=change-me-to-secure-password

# -----------------------------------------------------------------------------
# [OPTIONAL] STORAGE (required for file uploads)
# -----------------------------------------------------------------------------
# Supabase Storage for note markdown and attachments
# If not configured, file uploads will be disabled
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
KB_SUPABASE_STORAGE_BUCKET=notes
KB_SUPABASE_CACHE_CONTROL=31536000

# -----------------------------------------------------------------------------
# [OPTIONAL] FRONTEND CONFIGURATION
# -----------------------------------------------------------------------------
KB_FRONTEND_HOST=0.0.0.0
KB_FRONTEND_PORT=4311
KB_FRONTEND_BASE_PATH=/
KB_API_PROXY_TARGET=http://localhost:4310

# Frontend build configuration
VITE_KB_FRONTEND_BASE_PATH=/
VITE_KB_API_BASE_PATH=/api

# WhatsApp bot number for connection flow (digits only, with country code)
VITE_WHATSAPP_NUMBER=

# Telegram bot username for connection flow (without @)
VITE_TELEGRAM_BOT_USERNAME=

# File size limits (in bytes)
KB_ATTACHMENT_MAX_SIZE_BYTES=10485760
KB_AVATAR_MAX_SIZE_BYTES=3145728
VITE_ATTACHMENT_MAX_SIZE_BYTES=10485760

# -----------------------------------------------------------------------------
# [OPTIONAL] LOGGING CONFIGURATION
# -----------------------------------------------------------------------------
KB_LOG_PRETTY_CONSOLE=true
KB_LOG_FILE_ENABLED=true
KB_LOG_DIR=/var/log/kote
KB_LOG_MAX_FILES=30
KB_LOG_MAX_SIZE=20m
KB_LOG_LEVEL=info

# -----------------------------------------------------------------------------
# [OPTIONAL] NETWORK & PROXY CONFIGURATION
# -----------------------------------------------------------------------------
# Trust proxy (set to true when behind reverse proxy like nginx/traefik)
KB_TRUST_PROXY=false

# Body limit for HTTP requests (default: 15mb)
KB_BODY_LIMIT=15mb

# -----------------------------------------------------------------------------
# [OPTIONAL] AI CONFIGURATION
# -----------------------------------------------------------------------------
# AI providers are organized into 3 functional categories:
#   - Chat/LLM: review, conversation, project brief, PR context, file summary
#   - Embedding: semantic search indexing and CodeLens search
#   - Audio: voice note transcription
#
# Configuration hierarchy (per category):
#   1. Set KB_DEFAULT_<CATEGORY>_AI_* to configure all providers in that category
#   2. Override individual providers with their specific KB_<PROVIDER>_AI_* vars
#
# --- Chat/LLM default (used by all chat providers unless individually overridden) ---
# Provider options: 'gemini', 'openai', 'openrouter', 'ollama'
KB_DEFAULT_CHAT_AI_PROVIDER=openrouter
KB_DEFAULT_CHAT_AI_BASE_URL=https://openrouter.ai/api/v1
KB_DEFAULT_CHAT_AI_MODEL=openrouter/auto
KB_DEFAULT_CHAT_AI_API_KEY=

# --- Embedding default (used by the embedding worker and CodeLens search) ---
# Required for RAG/semantic search functionality
# Provider options: 'gemini', 'openai', 'ollama', 'openrouter'
KB_DEFAULT_EMBEDDING_AI_PROVIDER=gemini
KB_DEFAULT_EMBEDDING_AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
KB_DEFAULT_EMBEDDING_AI_MODEL=gemini-embedding-001
KB_DEFAULT_EMBEDDING_AI_API_KEY=

# --- Audio default (used for voice note transcription) ---
# Provider options: 'gemini', 'openai', 'openrouter', 'ollama'
KB_DEFAULT_AUDIO_AI_PROVIDER=gemini
KB_DEFAULT_AUDIO_AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
KB_DEFAULT_AUDIO_AI_MODEL=gemini-2.5-flash
KB_DEFAULT_AUDIO_AI_API_KEY=

# --- Per-provider overrides (optional — only set if you need different models per feature) ---
# Review AI (GitHub PR reviews, weekly summaries)
KB_REVIEW_AI_PROVIDER=
KB_REVIEW_AI_BASE_URL=
KB_REVIEW_AI_MODEL=
KB_REVIEW_AI_API_KEY=

# Conversation AI (chat, ask-knowledge queries)
KB_CONVERSATION_AI_PROVIDER=
KB_CONVERSATION_AI_BASE_URL=
KB_CONVERSATION_AI_MODEL=
KB_CONVERSATION_AI_API_KEY=

# Project Brief AI (project brief generation)
KB_PROJECT_BRIEF_AI_PROVIDER=
KB_PROJECT_BRIEF_AI_BASE_URL=
KB_PROJECT_BRIEF_AI_MODEL=
KB_PROJECT_BRIEF_AI_API_KEY=

# PR Context AI (pull request context extraction)
KB_PR_CONTEXT_AI_PROVIDER=
KB_PR_CONTEXT_AI_BASE_URL=
KB_PR_CONTEXT_AI_MODEL=
KB_PR_CONTEXT_AI_API_KEY=

# File Notes Summary AI (CodeLens file summary)
KB_FILE_NOTES_SUMMARY_AI_PROVIDER=
KB_FILE_NOTES_SUMMARY_AI_BASE_URL=
KB_FILE_NOTES_SUMMARY_AI_MODEL=
KB_FILE_NOTES_SUMMARY_AI_API_KEY=

# Embedding AI worker override
KB_EMBEDDING_AI_PROVIDER=
KB_EMBEDDING_AI_BASE_URL=
KB_EMBEDDING_AI_MODEL=
KB_EMBEDDING_AI_API_KEY=

# Audio AI override
KB_AUDIO_AI_PROVIDER=
KB_AUDIO_AI_BASE_URL=
KB_AUDIO_AI_MODEL=
KB_AUDIO_AI_API_KEY=

# CodeLens search AI override (defaults to KB_DEFAULT_EMBEDDING_AI_*)
KB_CODELENS_SEARCH_AI_PROVIDER=
KB_CODELENS_SEARCH_AI_BASE_URL=
KB_CODELENS_SEARCH_AI_MODEL=
KB_CODELENS_SEARCH_AI_API_KEY=

# Local Ollama service port (if using local Ollama)
KB_OLLAMA_PORT=11434

# -----------------------------------------------------------------------------
# [OPTIONAL] SEARCH & RAG HYPERPARAMETERS
# -----------------------------------------------------------------------------
# Search hyperparameters
KB_SEARCH_MIN_SIMILARITY=0.35
KB_SEARCH_CANDIDATE_LIMIT_MULTIPLIER=4
KB_SEARCH_HYBRID_VECTOR_WEIGHT=0.4
KB_SEARCH_HYBRID_KEYWORD_WEIGHT=0.6
KB_SEARCH_RRF_K=20

# CodeLens related notes search
KB_CODELENS_SEARCH_MIN_SIMILARITY=0.30
KB_CODELENS_SEARCH_CANDIDATE_LIMIT=20
KB_CODELENS_SEARCH_VECTOR_WEIGHT=0.4
KB_CODELENS_SEARCH_KEYWORD_WEIGHT=0.6
KB_CODELENS_SEARCH_RRF_K=20
KB_CODELENS_SEARCH_MAX_CONCURRENCY=2
KB_CODELENS_SEARCH_RESULT_LIMIT=5

# RAG hyperparameters
KB_RAG_MIN_SIMILARITY=0.45
KB_RAG_CANDIDATE_LIMIT=16
KB_RAG_HYBRID_VECTOR_WEIGHT=0.7
KB_RAG_HYBRID_KEYWORD_WEIGHT=0.3
KB_RAG_TOP_CHUNKS_LIMIT=10
KB_RAG_RRF_K=20

# Chunking hyperparameters
KB_CHUNK_TARGET_TOKENS=500
KB_CHUNK_OVERLAP_TOKENS=50
KB_CHUNK_MIN_CHARS=30
KB_CHUNK_CODE_BLOCK_OVERLAP_LINES=8
KB_EMBEDDING_DIMENSION=768

# -----------------------------------------------------------------------------
# [OPTIONAL] OAUTH CONFIGURATION
# -----------------------------------------------------------------------------
# Google OAuth (optional, for social login)
KB_GOOGLE_OAUTH_CLIENT_ID=
KB_GOOGLE_OAUTH_CLIENT_SECRET=
KB_GOOGLE_OAUTH_REDIRECT_URI=https://your-domain.com/api/auth/google/callback

# -----------------------------------------------------------------------------
# [OPTIONAL] WEBHOOK CONFIGURATION
# -----------------------------------------------------------------------------
# Webhook secret for validating incoming webhooks
KB_WEBHOOK_SECRET=

# Webhook paths
KB_GITHUB_WEBHOOK_PATH=/api/webhooks/github-push
KB_INGEST_WEBHOOK_PATH=/api/webhooks/ingest
KB_WPP_WEBHOOK_PATH=/api/webhooks/whatsapp
KB_QUERY_WEBHOOK_PATH=/api/webhooks/query

# Fallback webhook URL (used if KB_PUBLIC_BASE_URL is not set)
WEBHOOK_URL=

# Browser extension IDs (comma-separated, for chrome-extension:// origins)
KB_ALLOWED_EXTENSION_IDS=

# -----------------------------------------------------------------------------
# [OPTIONAL] GITHUB INTEGRATION
# -----------------------------------------------------------------------------
KB_GITHUB_APP_INSTALL_URL=https://github.com/apps/your-app/installations/new
KB_GITHUB_APP_CALLBACK_PATH=/api/integrations/github-app/callback
KB_GITHUB_APP_ID=
KB_GITHUB_APP_PRIVATE_KEY=
KB_GITHUB_APP_WEBHOOK_SECRET=
KB_GITHUB_BACKFILL_LIMIT=5

# -----------------------------------------------------------------------------
# [OPTIONAL] WHATSAPP INTEGRATION (Evolution API)
# -----------------------------------------------------------------------------
KB_WPP_WEBHOOK_API_KEY=
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE_NAME=
EVOLUTION_API_PUBLIC_URL=
KB_WPP_PAIRING_URL=
WPP_CONVERSATION_TIMEOUT_MS=600000

# -----------------------------------------------------------------------------
# [OPTIONAL] TELEGRAM INTEGRATION
# -----------------------------------------------------------------------------
KB_TELEGRAM_BOT_TOKEN=
KB_TELEGRAM_WEBHOOK_TOKEN=
KB_TELEGRAM_CHAT_ID=

# -----------------------------------------------------------------------------
# [OPTIONAL] EMAIL CONFIGURATION
# -----------------------------------------------------------------------------
# Email provider: 'resend' or 'smtp'
KB_EMAIL_PROVIDER=resend
KB_EMAIL_RESEND_API_KEY=
KB_EMAIL_FROM=Kote <no-reply@your-domain.com>
KB_EMAIL_SMTP_HOST=
KB_EMAIL_SMTP_PORT=587
KB_EMAIL_SMTP_USER=
KB_EMAIL_SMTP_PASS=
KB_EMAIL_SMTP_SECURE=false

# Email queue configuration
KB_EMAIL_QUEUE_EXCHANGE=kb.email
KB_EMAIL_QUEUE_NAME=kb.email.send
KB_EMAIL_QUEUE_ROUTING_KEY=kb.email.send
KB_EMAIL_WORKER_AUTORUN=true

# Email interception for development (sends all emails to DEV_EMAIL)
DEV_EMAIL_INTERCEPT=false
DEV_EMAIL=

# Test email authentication secret (for test email endpoints)
KB_TEST_EMAIL_AUTH_SECRET=

# Email branding
APP_NAME=Kote
APP_LOGO_URL=

# -----------------------------------------------------------------------------
# [OPTIONAL] PUSH NOTIFICATIONS (VAPID)
# -----------------------------------------------------------------------------
KB_VAPID_PUBLIC_KEY=
KB_VAPID_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# [OPTIONAL] PAYMENT GATEWAYS (Billing)
# -----------------------------------------------------------------------------
# Asaas Payment Gateway (Brazilian payment processor)
ASAAS_BASE_URL=https://api-sandbox.asaas.com/v3
ASAAS_ACCESS_TOKEN=
ASAAS_WEBHOOK_TOKEN=
ASAAS_CUSTOMER_NOTIFICATIONS_DISABLED=true

# Stripe Payment Gateway
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
ONLY_STRIPE=false

# -----------------------------------------------------------------------------
# [OPTIONAL] BILLING WORKERS
# -----------------------------------------------------------------------------
# Change Subscription Worker (applies scheduled downgrades/cycle changes)
CHANGE_SUBSCRIPTION_WORKER_AUTORUN=false

# Billing Worker (cancels PAST_DUE subscriptions after MAX_DAYS_PAST_DUE)
BILLING_WORKER_AUTORUN=false
MAX_DAYS_PAST_DUE=7

# Webhook Outbox Relay Worker (replays failed webhook events)
WEBHOOK_OUTBOX_RELAY_AUTORUN=false
WEBHOOK_OUTBOX_RELAY_CRON=*/1 * * * *
WEBHOOK_OUTBOX_RELAY_TIMEZONE=America/Sao_Paulo
WEBHOOK_OUTBOX_RELAY_BATCH_SIZE=100
WEBHOOK_OUTBOX_RELAY_MIN_AGE_SECONDS=30
WEBHOOK_OUTBOX_RELAY_MAX_ATTEMPTS=10

# RabbitMQ billing/webhook queue configuration
KB_RABBITMQ_BILLING_EXCHANGE=billing.webhooks
KB_RABBITMQ_BILLING_QUEUE=billing.webhooks.asaas
KB_RABBITMQ_BILLING_ROUTING_KEY=asaas.webhook
RABBITMQ_RETRY_DELAY_MS=15000
RABBITMQ_MAX_RETRIES=5
WEBHOOK_MAX_ATTEMPTS=10

# -----------------------------------------------------------------------------
# [OPTIONAL] DEBUGGING CONFIGURATION
# -----------------------------------------------------------------------------
# API inspector/debugger port
KB_API_INSPECT=false
KB_API_INSPECT_PORT=9229

# Integration tests flag
KB_RUN_INTEGRATION_TESTS=false

# -----------------------------------------------------------------------------
# [OPTIONAL] OPENTELEMETRY OBSERVABILITY
# -----------------------------------------------------------------------------
# OpenTelemetry service name (must be unique for this backend)
OTEL_SERVICE_NAME=kote-backend

# OpenTelemetry resource attributes (service metadata)
OTEL_RESOURCE_ATTRIBUTES=service.name=kote-backend,deployment.environment=development

# OpenTelemetry OTLP trace exporter endpoint
OTEL_EXPORTER_OTLP_ENDPOINT=http://10.0.0.52:4318/v1/traces
