# Runtime
NODE_ENV=development
KB_REMINDER_TIMEZONE=America/Sao_Paulo
KB_API_HOST=127.0.0.1
KB_API_PORT=4310
KB_API_PROXY_TARGET=http://localhost:4310
KB_FRONTEND_HOST=127.0.0.1
KB_FRONTEND_PORT=4311
KB_TRUST_PROXY=false
KB_BODY_LIMIT=10mb
LOG_PRETTY_CONSOLE=true
KB_LOG_PRETTY_CONSOLE=true

# Docker/Postgres local
KB_POSTGRES_PORT=5438
KB_POSTGRES_DB=knowledge_base
KB_POSTGRES_USER=postgres
KB_POSTGRES_PASSWORD=postgres

# Browser/API origin trust (fixes signup/login 403 invalid_origin)
KB_PUBLIC_BASE_URL=http://127.0.0.1:4311
KB_API_PUBLIC_BASE_URL=http://127.0.0.1:4310
KB_ALLOWED_ORIGINS=http://127.0.0.1:4311,http://localhost:4311,http://127.0.0.1:4310,http://localhost:4310

# Auth
KB_ADMIN_EMAIL=admin@example.com
KB_ADMIN_PASSWORD=change-me
KB_JWT_ACCESS_SECRET=change-me-access-secret
KB_JWT_REFRESH_SECRET=change-me-refresh-secret
KB_ACCESS_TOKEN_TTL_SECONDS=900
KB_REFRESH_TOKEN_TTL_SECONDS=2592000
KB_GOOGLE_OAUTH_CLIENT_ID=
KB_GOOGLE_OAUTH_CLIENT_SECRET=
KB_GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:4310/api/auth/google/callback
KB_INTERNAL_SERVICE_TOKEN=change-me-internal-token

# Persistence
KB_DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5438/knowledge_base
KB_DATABASE_URL_DOCKER=postgres://postgres:postgres@postgres:5432/knowledge_base

# Tests
KB_RUN_INTEGRATION_TESTS=true
KB_TEST_DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5438/knowledge_base_db_test
# Optional. Defaults to KB_TEST_DATABASE_URL with database "postgres".
KB_TEST_ADMIN_DATABASE_URL=

# Private Supabase Storage for note markdown and attachment bytes
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
KB_SUPABASE_STORAGE_BUCKET=
KB_SUPABASE_CACHE_CONTROL=31536000

# Credentials encryption (base64 of 32 bytes)
KB_CREDENTIALS_ENCRYPTION_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# Guided integrations
KB_GITHUB_APP_INSTALL_URL=https://github.com/apps/your-app/installations/new
KB_GITHUB_APP_CALLBACK_PATH=/api/integrations/github-app/callback
KB_GITHUB_APP_CLIENT_ID=
KB_GITHUB_APP_CLIENT_SECRET=
KB_GITHUB_APP_ID=
KB_GITHUB_APP_PRIVATE_KEY=
KB_GITHUB_APP_WEBHOOK_SECRET=
KB_WPP_WEBHOOK_PATH=/api/webhooks/whatsapp
KB_WPP_WEBHOOK_API_KEY=
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE_NAME=
EVOLUTION_API_PUBLIC_URL=
KB_TELEGRAM_BOT_TOKEN=
KB_TELEGRAM_WEBHOOK_TOKEN=
# Legado/manual para automacoes antigas. O worker oficial de reminders usa o chat conectado no workspace.
KB_TELEGRAM_CHAT_ID=

# Managed AI integrations
KB_REVIEW_AI_PROVIDER=openrouter
KB_REVIEW_AI_BASE_URL=https://openrouter.ai/api/v1
KB_REVIEW_AI_MODEL=openrouter/auto
KB_REVIEW_AI_API_KEY=
KB_CONVERSATION_AI_PROVIDER=openrouter
KB_CONVERSATION_AI_BASE_URL=https://openrouter.ai/api/v1
KB_CONVERSATION_AI_MODEL=openrouter/auto
KB_CONVERSATION_AI_API_KEY=
# Defaults to KB_CONVERSATION_AI_* when left blank.
KB_PROJECT_BRIEF_AI_PROVIDER=
KB_PROJECT_BRIEF_AI_BASE_URL=
KB_PROJECT_BRIEF_AI_MODEL=
KB_PROJECT_BRIEF_AI_API_KEY=

# Embedding AI (semantic search)
# Defaults to Gemini embedding API. Set provider to 'openai' or 'openrouter' for OpenAI-compatible endpoints.
KB_EMBEDDING_AI_PROVIDER=gemini
KB_EMBEDDING_AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
KB_EMBEDDING_AI_MODEL=gemini-embedding-001
KB_EMBEDDING_AI_API_KEY=

# RabbitMQ (embedding queue)
KB_RABBITMQ_URL=amqp://kb:kb_dev@127.0.0.1:5672
KB_RABBITMQ_USER=kb
KB_RABBITMQ_PASSWORD=kb_dev
KB_RABBITMQ_PORT=5672
KB_RABBITMQ_MANAGEMENT_PORT=15672
KB_DISABLE_EMBEDDING_WORKER=false

# Push Notifications (VAPID)
KB_VAPID_PUBLIC_KEY=
KB_VAPID_PRIVATE_KEY=
KB_FRONTEND_BASE_PATH=/
