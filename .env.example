# Runtime
NODE_ENV=development
KB_API_HOST=127.0.0.1
KB_API_PORT=4310
KB_API_PROXY_TARGET=http://localhost:4310
KB_FRONTEND_HOST=127.0.0.1
KB_FRONTEND_PORT=4311
KB_TRUST_PROXY=false
KB_BODY_LIMIT=1mb
LOG_PRETTY_CONSOLE=true
KB_LOG_PRETTY_CONSOLE=true

# Docker/Postgres local
KB_POSTGRES_PORT=5432
KB_POSTGRES_DB=knowledge_base
KB_POSTGRES_USER=postgres
KB_POSTGRES_PASSWORD=postgres

# Browser/API origin trust (fixes signup/login 403 invalid_origin)
KB_PUBLIC_BASE_URL=http://127.0.0.1:4310
KB_ALLOWED_ORIGINS=http://127.0.0.1:4311,http://localhost:4311,http://127.0.0.1:4310,http://localhost:4310

# Auth
KB_ADMIN_EMAIL=admin@example.com
KB_ADMIN_PASSWORD=change-me
KB_JWT_ACCESS_SECRET=change-me-access-secret
KB_JWT_REFRESH_SECRET=change-me-refresh-secret
KB_ACCESS_TOKEN_TTL_SECONDS=900
KB_REFRESH_TOKEN_TTL_SECONDS=2592000
KB_INTERNAL_SERVICE_TOKEN=change-me-internal-token

# Persistence
KB_DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/knowledge_base
KB_DATABASE_URL_DOCKER=postgres://postgres:postgres@postgres:5432/knowledge_base

# Credentials encryption (base64 of 32 bytes)
KB_CREDENTIALS_ENCRYPTION_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# Guided integrations
KB_GITHUB_APP_INSTALL_URL=https://github.com/apps/your-app/installations/new
KB_GITHUB_APP_CLIENT_ID=
KB_GITHUB_APP_CLIENT_SECRET=
KB_GITHUB_APP_ID=
KB_GITHUB_APP_PRIVATE_KEY=
KB_GITHUB_APP_WEBHOOK_SECRET=
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE_NAME=
EVOLUTION_API_PUBLIC_URL=
KB_WPP_PAIRING_URL=
KB_TELEGRAM_BOT_TOKEN=
KB_TELEGRAM_WEBHOOK_TOKEN=
KB_TELEGRAM_CHAT_ID=

# Managed AI integrations
KB_REVIEW_AI_PROVIDER=openrouter
KB_REVIEW_AI_BASE_URL=https://openrouter.ai/api/v1
KB_REVIEW_AI_MODEL=openrouter/auto
KB_REVIEW_AI_API_KEY=
KB_CONVERSATION_AI_PROVIDER=openrouter
KB_CONVERSATION_AI_BASE_URL=https://openrouter.ai/api/v1
KB_CONVERSATION_AI_MODEL=openrouter/auto
KB_CONVERSATION_AI_API_KEY=
