# GitHub Environment Variables (production) (example)

VPS_APP_DIR=
FRONTEND_DEPLOY_PATH=/var/www/kote
RELOAD_NGINX=true
VITE_KB_FRONTEND_BASE_PATH=/kote/
VITE_KB_API_BASE_PATH=/kote/api

NODE_ENV=
KB_API_HOST=
KB_API_PORT=
KB_TRUST_PROXY=
KB_BODY_LIMIT=10mb
LOG_PRETTY_CONSOLE=true
KB_LOG_PRETTY_CONSOLE=true
KB_LOG_FILE_ENABLED=true
KB_LOG_DIR=/var/log/kote-api
KB_LOG_MAX_FILES=30
KB_LOG_MAX_SIZE=20m
KB_LOG_LEVEL=info
KB_PUBLIC_BASE_URL=
KB_API_PUBLIC_BASE_URL=
KB_ALLOWED_ORIGINS=
KB_ALLOWED_EXTENSION_IDS=
KB_ACCESS_TOKEN_TTL_SECONDS=
KB_REFRESH_TOKEN_TTL_SECONDS=
KB_GOOGLE_OAUTH_REDIRECT_URI=
KB_DATABASE_SSL_MODE=
KB_DATABASE_SSL_REJECT_UNAUTHORIZED=
SUPABASE_URL=
KB_SUPABASE_STORAGE_BUCKET=
KB_SUPABASE_CACHE_CONTROL=31536000

KB_GITHUB_APP_INSTALL_URL=
KB_GITHUB_BACKFILL_LIMIT=5

EVOLUTION_API_URL=
EVOLUTION_INSTANCE_NAME=
EVOLUTION_API_PUBLIC_URL=
KB_WPP_PAIRING_URL=

KB_TELEGRAM_CHAT_ID=

KB_REVIEW_AI_PROVIDER=
KB_REVIEW_AI_BASE_URL=
KB_REVIEW_AI_MODEL=
KB_CONVERSATION_AI_PROVIDER=
KB_CONVERSATION_AI_BASE_URL=
KB_CONVERSATION_AI_MODEL=
KB_PROJECT_BRIEF_AI_PROVIDER=
KB_PROJECT_BRIEF_AI_BASE_URL=
KB_PROJECT_BRIEF_AI_MODEL=
KB_PR_CONTEXT_AI_PROVIDER=
KB_PR_CONTEXT_AI_BASE_URL=
KB_PR_CONTEXT_AI_MODEL=

KB_SEARCH_MIN_SIMILARITY=0.3
KB_SEARCH_CANDIDATE_LIMIT_MULTIPLIER=3
KB_SEARCH_HYBRID_VECTOR_WEIGHT=0.4
KB_SEARCH_HYBRID_KEYWORD_WEIGHT=0.6
KB_RAG_MIN_SIMILARITY=0.35
KB_RAG_CANDIDATE_LIMIT=16
KB_RAG_HYBRID_VECTOR_WEIGHT=0.8
KB_RAG_HYBRID_KEYWORD_WEIGHT=0.2
KB_RAG_TOP_CHUNKS_LIMIT=8
