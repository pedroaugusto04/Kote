# GitHub Environment Secrets (production) (example)

VPS_HOST=
VPS_USER=
VPS_SSH_PORT=22
# Store as a single line with literal \n separators.
# Use PEM headers like BEGIN PRIVATE KEY or BEGIN RSA PRIVATE KEY.
VPS_SSH_PRIVATE_KEY=
# GitHub token used by the VPS deploy step for git fetch/pull on private repos.
# Prefer a fine-grained token scoped to this repository contents.
VPS_GITHUB_REPO_TOKEN=

KB_DATABASE_URL=
KB_ADMIN_EMAIL=
KB_ADMIN_PASSWORD=
KB_JWT_ACCESS_SECRET=
KB_JWT_REFRESH_SECRET=
KB_GOOGLE_OAUTH_CLIENT_ID=
KB_GOOGLE_OAUTH_CLIENT_SECRET=
KB_INTERNAL_SERVICE_TOKEN=
KB_CREDENTIALS_ENCRYPTION_KEY=
KB_TEST_EMAIL_AUTH_SECRET=
SUPABASE_SERVICE_ROLE_KEY=

KB_GITHUB_APP_ID=
# Store as a single line with literal \n separators.
# GitHub App keys should stay in PEM format.
KB_GITHUB_APP_PRIVATE_KEY=
KB_GITHUB_APP_WEBHOOK_SECRET=

KB_WPP_WEBHOOK_API_KEY=
EVOLUTION_API_KEY=

KB_TELEGRAM_BOT_TOKEN=
KB_TELEGRAM_WEBHOOK_TOKEN=

KB_REVIEW_AI_API_KEY=
KB_CONVERSATION_AI_API_KEY=
KB_PROJECT_BRIEF_AI_API_KEY=
KB_PR_CONTEXT_AI_API_KEY=
KB_EMBEDDING_AI_API_KEY=
