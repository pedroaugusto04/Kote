# Runtime
NODE_ENV=development
KB_API_HOST=127.0.0.1
KB_API_PORT=4310
KB_FRONTEND_PORT=4311
KB_TRUST_PROXY=false
KB_BODY_LIMIT=1mb

# Docker/Postgres local
KB_POSTGRES_PORT=5432
KB_POSTGRES_DB=knowledge_base
KB_POSTGRES_USER=postgres
KB_POSTGRES_PASSWORD=postgres

# Browser/API origin trust (fixes signup/login 403 invalid_origin)
KB_PUBLIC_BASE_URL=http://127.0.0.1:4310
KB_ALLOWED_ORIGINS=http://127.0.0.1:4311,http://localhost:4311,http://127.0.0.1:4310,http://localhost:4310

# Auth
KB_ADMIN_EMAIL=pedroaugustoaduarte@gmail.com
KB_ADMIN_PASSWORD=Pedro@D18
KB_JWT_ACCESS_SECRET=change-me-access-secret
KB_JWT_REFRESH_SECRET=change-me-refresh-secret
KB_ACCESS_TOKEN_TTL_SECONDS=900
KB_REFRESH_TOKEN_TTL_SECONDS=2592000
KB_INTERNAL_SERVICE_TOKEN=change-me-internal-token

# Persistence
KB_DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/knowledge_base
KB_DATABASE_URL_DOCKER=postgres://postgres:postgres@postgres:5432/knowledge_base

# Credentials encryption (base64 of 32 bytes)
KB_CREDENTIALS_ENCRYPTION_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
