{
  "name": "@n8n-automations/knowledge-base",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "build:api": "npm run clean && tsc -p backend/tsconfig.json && cp -r backend/src/infrastructure/email/templates backend/dist/infrastructure/email/",
    "build:frontend": "vite build --config frontend/vite.config.ts",
    "build:cli": "tsc -p cli/tsconfig.json",
    "build": "npm run clean && npm run build:api && npm run build:frontend && npm run build:cli",
    "dev:api": "node scripts/dev-api.mjs",
    "dev:frontend": "vite --config frontend/vite.config.ts",
    "migrate": "npm run build:api && node backend/dist/infrastructure/persistence/run-migrations.js",
    "test:api": "node scripts/run-api-tests.mjs",
    "test:cli": "node scripts/run-cli-tests.mjs",
    "test:frontend": "vitest run --config frontend/vite.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:headed": "playwright test --headed",
    "test:integration": "vitest run --config frontend/vite.config.ts frontend/test/integration",
    "test": "npm run test:api && npm run test:cli && npm run test:frontend && npm run test:integration",
    "cli": "npm run build:cli && node cli/dist/index.js"
  },
  "dependencies": {
    "@clack/prompts": "^1.5.0",
    "@hookform/resolvers": "^5.2.2",
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/swagger": "^11.4.4",
    "@stripe/react-stripe-js": "^3.10.0",
    "@stripe/stripe-js": "^5.10.0",
    "@supabase/supabase-js": "^2.105.1",
    "@tanstack/query-sync-storage-persister": "^5.101.0",
    "@tanstack/react-query": "^5.62.8",
    "@tanstack/react-query-persist-client": "^5.101.0",
    "@types/d3": "^7.4.3",
    "amqplib": "^2.0.1",
    "commander": "^15.0.0",
    "d3": "^7.9.0",
    "decimal.js": "^10.6.0",
    "dompurify": "^3.4.10",
    "drizzle-orm": "^0.45.2",
    "google-auth-library": "^10.6.2",
    "node-cron": "^4.4.1",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.20.0",
    "picocolors": "^1.1.1",
    "prismjs": "^1.30.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.74.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.1.1",
    "recharts": "^3.8.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sonner": "^2.0.7",
    "web-push": "^3.6.7",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^3.25.76",
    "nodemailer": "^8.0.4",
    "resend": "^6.10.0",
    "handlebars": "^4.7.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/amqplib": "^0.10.8",
    "@types/decimal.js": "^0.0.32",
    "@types/dompurify": "^3.0.5",
    "@types/express": "^5.0.0",
    "@types/node": "^24.3.0",
    "@types/pg": "^8.20.0",
    "@types/prismjs": "^1.26.6",
    "@types/react": "^19.0.2",
    "@types/nodemailer": "^7.0.11",
    "@types/react-dom": "^19.0.2",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react": "^5.2.0",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^25.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2",
    "vite": "^7.3.2",
    "vitest": "^4.1.5"
  }
}
