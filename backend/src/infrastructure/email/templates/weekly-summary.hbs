<h1>Olá, {{displayName}}!</h1>
<p>Aqui está o resumo da sua atividade semanal no {{appName}}.</p>

{{#projects}}
  <h3 style="margin: 16px 0 8px;">{{projectName}} — {{count}} nota(s)</h3>
  <ul>
    {{#notes}}
      <li>{{title}} — {{date}}</li>
    {{/notes}}
  </ul>
{{/projects}}

<p style="margin-top: 18px;">
  <a href="{{frontUrl}}/"
     style="display:inline-block; padding:12px 24px; background-color:#53c7de; color:#090f14; text-decoration:none; border-radius:8px;">
     Abrir Knowledge Base
  </a>
</p>

<p>Obrigado!</p>
