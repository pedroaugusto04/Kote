<h1>Alerta de Code Review AI</h1>

<p><strong>Projeto:</strong> {{projectSlug}}</p>
<p><strong>Repositório:</strong> {{repoFullName}}</p>
<p><strong>Commit:</strong> {{commitSha}}</p>
{{#if compareUrl}}
<p><strong>Comparar:</strong> <a href="{{compareUrl}}">{{compareUrl}}</a></p>
{{/if}}
{{#if noteLink}}
<p><strong>Detalhes da nota:</strong> <a href="{{noteLink}}">{{noteLink}}</a></p>
{{/if}}

<h2 style="margin: 16px 0 8px;">Resumo</h2>
<p>{{summary}}</p>
{{#if impact}}
<p><strong>Impacto:</strong></p>
<p>{{impact}}</p>
{{/if}}

<h2 style="margin: 16px 0 8px;">Problemas Importantes</h2>
{{#each findings}}
<div style="margin: 12px 0; padding: 12px; background-color: #fef2f2; border-left: 4px solid #dc2626; border-radius: 4px;">
  <p style="margin: 0 0 8px;"><strong>{{severity}}</strong>{{#if file}} ({{file}}){{/if}}</p>
  <p style="margin: 0 0 8px;"><strong>Problema:</strong> {{summary}}</p>
  <p style="margin: 0;"><strong>Como corrigir:</strong> {{recommendation}}</p>
</div>
{{/each}}

<p style="margin-top: 18px;">
  <a href="{{frontUrl}}/"
     style="display:inline-block; padding:12px 24px; background-color:#0ea5e9; color:white; text-decoration:none; border-radius:8px;">
     Abrir Knowledge Base
  </a>
</p>
